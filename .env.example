# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase (service_role: Supabase → Project Settings → API → service_role — NUNCA use prefixo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AeroDataBox (via RapidAPI) — status de voos em Embarques, cobre datas futuras
# Obtenha em https://rapidapi.com/aedbx-aedbx/api/aerodatabox (plano Basic gratuito, 600 units/mês)
AERODATABOX_API_KEY=

# Aviationstack — fallback de status de voos (plano free: só tempo real)
# Obtenha em https://aviationstack.com/
AVIATIONSTACK_ACCESS_KEY=
# free (padrão: tenta filtros e cai para tempo real) | paid (usa flight_date e filtros)
AVIATIONSTACK_PLAN=free
